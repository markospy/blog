---
import AboutHeroImage from '../assets/avatar-blog.png';
import Layout from '../layouts/BlogPost.astro';

// Icones de https://icon-sets.iconify.design/skill-icons/ (Iconify – Skill Icons), variante light
const techStack: { name: string; icon: string }[] = [
  { name: 'FastAPI', icon: 'fastapi' },
  { name: 'React', icon: 'react-light' },
  { name: 'React Native', icon: 'react-light' },
  { name: 'Next.js', icon: 'nextjs-light' },
  { name: 'Expo', icon: 'react-light' },
  { name: 'PostgreSQL', icon: 'postgresql-light' },
  { name: 'HTML', icon: 'html' },
  { name: 'CSS', icon: 'css' },
  { name: 'JavaScript', icon: 'javascript' },
  { name: 'TypeScript', icon: 'typescript' },
  { name: 'Python', icon: 'python-light' },
  { name: 'SQLModel', icon: 'python-light' },
  { name: 'SQLAlchemy', icon: 'python-light' },
  { name: 'Pydantic', icon: 'python-light' },
  { name: 'MongoDB', icon: 'mongodb' },
  { name: 'Docker', icon: 'docker' },
  { name: 'Git', icon: 'git' },
  { name: 'Pytest', icon: 'python-light' },
  { name: 'N8N', icon: 'nodejs-light' },
];
const iconifyBase = 'https://api.iconify.design/skill-icons';
---

<Layout
  title="Sobre mí"
  description="Marcos Antonio Ávila Morales — Full Stack Developer. Perfil profesional y stack tecnológico."
  heroImage={AboutHeroImage}
  showDate={false}
>
  <p>
    Soy <strong>Marcos Antonio Ávila Morales</strong>, ingeniero de software Full Stack con más de tres años de experiencia
    desarrollando aplicaciones en producción. Me especializo en backend con FastAPI, frontend con React e integraciones de modelos de inteligencia artifical. Me enfoco en soluciones robustas, escalables y alineadas con el negocio.
  </p>

  <p>
    He liderado el desarrollo de plataformas desde cero hasta MVP y su crecimiento (por ejemplo, más de 40 gimnasios
    y miles de usuarios en un sistema de gestión), he trabajado con Clean Architecture y arquitectura por capas,
    y me interesa el equilibrio entre calidad técnica y velocidad de entrega. También tengo experiencia en
    proyectos freelance, integración con LLMs (RAGs, agentes) y productos SaaS.
  </p>

  <p>
    Me gusta el enfoque pragmático: elegir la arquitectura adecuada al contexto, refactorizar con criterio
    y mantener el foco en el impacto real del software.
  </p>

  <section class="margin-top-large">
    <h2 class="margin-bottom">Stack tecnológico</h2>
    <div class="tech-stack">
      {techStack.map(({ name, icon }) => (
        <div class="tech-item" title={name}>
          <img
            src={`${iconifyBase}/${icon}.svg`}
            alt=""
            width="28"
            height="28"
            class="tech-icon"
          />
          <span class="tech-name">{name}</span>
        </div>
      ))}
    </div>
  </section>
</Layout>
