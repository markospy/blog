---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostList from '../../components/PostList.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const tags = [...new Set(allPosts.flatMap((p) => p.data.tags ?? []))].sort();
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>

  <body>
    <Header />

    <main class="container container--responsive padding-large">

      <p class="text-center">
        Bienvenido a mi blog. Aquí podrás encontrar todo tipo de artículos, desde técnicos (solo unos pocos) a temas más humanos, como mi experiencia de crecimiento en el camino de la programación.
      </p>

      <nav class="row flex-center margin-top-large margin-bottom-none" aria-label="Filtrar por etiqueta">
        <span class="margin-right-small">Filtrar:</span>
        <a href={`${import.meta.env.BASE_URL}articles/`} class="blog-tag paper-btn btn-small margin-right-small">Todos</a>
        {
          tags.map((tag) => (
            <a
              href={`${import.meta.env.BASE_URL}articles/?tag=${encodeURIComponent(tag)}`}
              class="blog-tag paper-btn btn-small margin-right-small"
            >
              {tag}
            </a>
          ))
        }
      </nav>

      <section class="margin-top-large">
        <PostList posts={allPosts} listId="blog-list" filterable />
      </section>

    </main>

    <script>
      function filterByTag() {
        const params = new URLSearchParams(window.location.search);
        const tag = params.get('tag')?.toLowerCase();
        const items = document.querySelectorAll('.blog-list-item');
        const tagLinks = document.querySelectorAll('.blog-tag');
        tagLinks.forEach((a) => {
          const hrefTag = new URL(a.getAttribute('href') ?? '', window.location.origin).searchParams.get('tag')?.toLowerCase();
          a.classList.toggle('active', !tag ? a.textContent?.trim() === 'Todos' : hrefTag === tag);
        });
        items.forEach((el) => {
          const tags = (el.getAttribute('data-tags') ?? '').split(',').filter(Boolean);
          const show = !tag || tags.includes(tag);
          (el as HTMLElement).style.display = show ? '' : 'none';
        });
      }
      filterByTag();
      window.addEventListener('popstate', filterByTag);
    </script>

    <Footer />
  </body>
</html>
