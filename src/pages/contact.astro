---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

import OgImage from '../assets/avatar-blog.jpg';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${SITE_TITLE} – Contact`} description={SITE_DESCRIPTION} image={OgImage} />
  </head>

  <body>
    <Header />

    <!--
      Formulario → webhook n8n → tu flujo envía a Telegram.
      Configura PUBLIC_N8N_WEBHOOK_URL con la URL del webhook de tu flujo n8n
      (en .env o en los secrets de GitHub Actions para el build).
    -->

    <main class="container container--responsive padding-small">

      <div class="paper padding-top-small">

        <h1 class="text-center">
          Contact
        </h1>

        <p class="text-center">


        <form
          action={import.meta.env.PUBLIC_N8N_WEBHOOK_URL ?? ''}
          method="POST"
          class="margin-top-large"
        >

          <div class="form-group">
            <label for="name">Your Name</label>
            <input class="input-block" type="text" id="name" name="name" required>
          </div>

          <div class="form-group">
            <label for="email">Your Email</label>
            <input class="input-block" type="email" id="email" name="email" required>
          </div>

          <div class="form-group">
            <label for="subject">Subject</label>
            <select id="subject" name="subject" class="input-block">
              <option value="general">General Message</option>
              <option value="feedback">Feedback</option>
              <option value="support">Support Request</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Your Message</label>
            <textarea class="input-block no-resize" id="message" name="message" rows="6" required></textarea>
          </div>

          <fieldset class="form-group">
            <legend>Stay Updated</legend>

            <label class="paper-check" for="newsletter">
              <input type="checkbox" id="newsletter" name="newsletter" value="yes">
              <span>Subscribe to updates</span>
            </label>
          </fieldset>

          <button type="submit" class="paper-btn btn-primary btn-block margin-top">
            Send Message
          </button>

        </form>

        {!import.meta.env.PUBLIC_N8N_WEBHOOK_URL && (
          <p class="text-center margin-top margin-left margin-right" style="color: var(--muted); font-size: 0.9rem;">
            Configura <code>PUBLIC_N8N_WEBHOOK_URL</code> con la URL del webhook de n8n para activar el envío.
          </p>
        )}

      </div>

    </main>

    <Footer />

    <style>
      .inline-icon {
        display: inline-flex;
        vertical-align: middle;
        margin-right: 0.35rem;
      }
    </style>
  </body>
</html>

