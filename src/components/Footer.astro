---
import ScrollToTop from './ScrollToTop.astro';
const year = new Date().getFullYear();
---

<ScrollToTop />
<footer class="padding-large text-center margin-top-large">
  <p class="margin-none">© {year} markospy</p>
  <a
    href="https://github.com/markospy"
    target="_blank"
    rel="noopener noreferrer"
    class="paper-btn btn-small margin-top-small footer-link"
  >
    <svg class="margin-right-small" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M12 2a10 10 0 0 0-3 19.5c.5.1.7-.2.7-.5v-2c-3 .7-3.6-1.5-3.6-1.5-.5-1.2-1.2-1.5-1.2-1.5-1-.7.1-.7.1-.7 1 .1 1.6 1 1.6 1 .9 1.6 2.4 1.1 3 .8.1-.7.4-1.1.7-1.4-2.4-.3-5-1.2-5-5.4 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.6 0 0 .8-.3 2.7 1a9.3 9.3 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1 .5 1.3.2 2.3.1 2.6.6.7 1 1.6 1 2.7 0 4.2-2.6 5.1-5 5.4.4.3.8 1 .8 2v3c0 .3.2.6.7.5A10 10 0 0 0 12 2z"/>
    </svg>
    GitHub
  </a>
</footer>

<style>
  .footer-link {
    display: inline-block;
  }
  footer svg {
    display: inline-block;
    vertical-align: middle;
  }
</style>

