---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/avatar-blog.png';
import { SITE_TITLE } from '../consts';

interface Props {
        title: string;
        description: string;
        image?: ImageMetadata;
        /** Autor del contenido (p. ej. para artículos). Se usa en meta author y og:article:author. */
        author?: string;
        /** Tipo de página para Open Graph. Si es "article", se añaden article:author y fechas. */
        type?: 'website' | 'article';
        /** Fecha de publicación (ISO). Solo relevante si type === 'article'. */
        pubDate?: Date;
        /** Fecha de última modificación (ISO). Solo relevante si type === 'article'. */
        updatedDate?: Date;
}

const base = import.meta.env.BASE_URL;
const siteOrigin = Astro.site?.href?.replace(/\/$/, '') ?? Astro.url.origin;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? siteOrigin);

const { title, description, image = FallbackImage, author, type = 'website', pubDate, updatedDate } = Astro.props;
// URL absoluta de la imagen para og:image / twitter:image (redes sociales requieren URL absoluta)
const rawPath = typeof image.src === 'string' ? image.src : '';
const imageUrl =
  rawPath.startsWith('http://') || rawPath.startsWith('https://')
    ? rawPath
    : (() => {
        const basePath = base.endsWith('/') ? base.slice(0, -1) : base;
        const pathWithSlash = rawPath.startsWith('/') ? rawPath : `/${rawPath}`;
        const pathWithBase = basePath && !pathWithSlash.startsWith(basePath) ? `${basePath}${pathWithSlash}` : pathWithSlash;
        return new URL(pathWithBase, siteOrigin).href;
      })();
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
<link rel="icon" href={`${base}favicon.png`} />
<link rel="sitemap" href={`${base}sitemap-index.xml`} />

<!-- Global CSS -->
<link rel="stylesheet" href="https://unpkg.com/papercss@1.9.2/dist/paper.min.css" />

<link
        rel="alternate"
        type="application/rss+xml"
        title={SITE_TITLE}
        href={new URL(`${base}rss.xml`, Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href={`${base}fonts/atkinson-regular.woff`} as="font" type="font/woff" crossorigin />
<link rel="preload" href={`${base}fonts/atkinson-bold.woff`} as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
{author && <meta name="author" content={author} />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />
{image.width && image.height && (
  <>
    <meta property="og:image:width" content={String(image.width)} />
    <meta property="og:image:height" content={String(image.height)} />
  </>
)}
{type === 'article' && author && <meta property="article:author" content={author} />}
{type === 'article' && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{type === 'article' && updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageUrl} />
{image.width && image.height && (
  <>
    <meta property="twitter:image:width" content={String(image.width)} />
    <meta property="twitter:image:height" content={String(image.height)} />
  </>
)}

<!-- Aplicar tema guardado (PaperCSS dark mode) antes de pintar -->
<script is:inline>
  (function(){ try { if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark'); } catch (e) {} })();
</script>
