---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/avatar-blog.png';
import { SITE_TITLE } from '../consts';

interface Props {
        title: string;
        description: string;
        image?: ImageMetadata;
}

const base = import.meta.env.BASE_URL;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = FallbackImage } = Astro.props;
// URL absoluta de la imagen para og:image / twitter:image (WhatsApp, Telegram, etc.)
const imagePath = (base.endsWith('/') ? base.slice(0, -1) : base) + (image.src.startsWith('/') ? image.src : `/${image.src}`);
const imageUrl = new URL(imagePath, Astro.site).href;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
<link rel="icon" href={`${base}favicon.png`} />
<link rel="sitemap" href={`${base}sitemap-index.xml`} />

<!-- Global CSS -->
<link rel="stylesheet" href="https://unpkg.com/papercss@1.9.2/dist/paper.min.css" />

<link
        rel="alternate"
        type="application/rss+xml"
        title={SITE_TITLE}
        href={new URL(`${base}rss.xml`, Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href={`${base}fonts/atkinson-regular.woff`} as="font" type="font/woff" crossorigin />
<link rel="preload" href={`${base}fonts/atkinson-bold.woff`} as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageUrl} />

<!-- Aplicar tema guardado (PaperCSS dark mode) antes de pintar -->
<script is:inline>
  (function(){ try { if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark'); } catch (e) {} })();
</script>
