---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = import.meta.env.BASE_URL;
---

<header class="padding-top-small">
  <div class="container container--responsive header-container">
    <nav class="row padding-small margin-bottom-none header-nav">
      <div class="header-nav-spacer"></div>
      <div class="row flex-center margin-bottom-none">
        <HeaderLink href={base} class="paper-btn btn-small margin-right-small">{SITE_TITLE}</HeaderLink>
        <HeaderLink href={`${base}articles`} class="paper-btn btn-small margin-right-small">Blog</HeaderLink>
        <HeaderLink href={`${base}about`} class="paper-btn btn-small margin-right-small">About me</HeaderLink>
        <HeaderLink href={`${base}contact`} class="paper-btn btn-small">Contact</HeaderLink>
      </div>
      <div class="row flex-right margin-bottom-none">
        <button type="button" class="paper-btn btn-small btn-round" id="dark-mode-toggle" aria-label="Alternar modo oscuro">
          <span class="theme-icon-sun" aria-hidden="true"></span>
          <span class="theme-icon-moon" aria-hidden="true"></span>
        </button>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  (function() {
    var html = document.documentElement;
    var btn = document.getElementById('dark-mode-toggle');
    if (!btn) return;
    function updateLabel() {
      btn.setAttribute('aria-label', html.classList.contains('dark') ? 'Cambiar a modo claro' : 'Cambiar a modo oscuro');
    }
    updateLabel();
    btn.addEventListener('click', function() {
      html.classList.toggle('dark');
      try { localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light'); } catch (e) {}
      updateLabel();
    });
  })();
</script>
