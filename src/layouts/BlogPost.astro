---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { showDate?: boolean };

const { title, description, pubDate, updatedDate, heroImage, tags = [], showDate = true } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body>
    <Header />

    <main class="container container--responsive padding-large article-layout-narrow">
      <article class="article--responsive">

        <h1 class="article-title text-center margin-bottom-small">{title}</h1>

        {heroImage && (
          <Image
            width={600}
            height={300}
            src={heroImage}
            alt={title}
            class="article-hero margin-bottom-small"
          />
        )}

        {tags.length > 0 && (
          <p class="row flex-center margin-bottom-small">
            {tags.map((tag) => (
              <span class="badge primary margin-right-small margin-bottom-small">{tag}</span>
            ))}
          </p>
        )}

        {showDate && pubDate && (
          <p class="text-center margin-bottom-large">
            Published on <FormattedDate date={pubDate} />
            {updatedDate && (
              <>
                <br />
                <span class="italic">
                  Last updated on <FormattedDate date={updatedDate} />
                </span>
              </>
            )}
          </p>
        )}

        <slot />

        <hr />


      </article>
    </main>

    <Footer />
  </body>
</html>

