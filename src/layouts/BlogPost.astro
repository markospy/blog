---
import { Image, getImage } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR } from '../consts';

import FallbackOgImage from '../assets/avatar-blog.jpg';

type Props = CollectionEntry<'blog'>['data'] & { showDate?: boolean };

const { title, description, pubDate, updatedDate, heroImage, tags = [], showDate = true } = Astro.props;
const base = import.meta.env.BASE_URL;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
// Usar getImage() para que og:image tenga la URL del build (redes sociales requieren URL que exista en producción)
const ogImage = await getImage({ src: heroImage ?? FallbackOgImage });
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Person', name: SITE_AUTHOR },
  datePublished: pubDate?.toISOString(),
  dateModified: (updatedDate ?? pubDate)?.toISOString(),
  url: canonicalUrl,
};
---

<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={ogImage}
      author={SITE_AUTHOR}
      type="article"
      pubDate={pubDate}
      updatedDate={updatedDate}
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body>
    <Header />

    <main class="container container--responsive padding-large article-layout-narrow">
      <article class="article--responsive">

        <h1 class="article-title text-center margin-bottom-small">{title}</h1>

        {heroImage && (
          <Image
            width={600}
            height={300}
            src={heroImage}
            alt={title}
            class="article-hero margin-bottom-small"
          />
        )}

        {tags.length > 0 && (
          <p class="row flex-center">
            {tags.map((tag) => (
              <a
                href={`${base}articles/?tag=${encodeURIComponent(tag)}`}
                class="badge primary margin-right-small no-decoration"
              >
                {tag}
              </a>
            ))}
          </p>
        )}

        {showDate && pubDate && (
          <p class="text-center margin-bottom-large">
            Published on <FormattedDate date={pubDate} />
            {updatedDate && (
              <>
                <br />
                <span class="italic">
                  Last updated on <FormattedDate date={updatedDate} />
                </span>
              </>
            )}
          </p>
        )}

        <slot />

        <hr />


      </article>
    </main>

    <Footer />
  </body>
</html>

